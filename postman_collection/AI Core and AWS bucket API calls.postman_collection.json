    {
      "name": "Get All Scenarios",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let response = pm.response.json();\r",
              "\r",
              "// extract all scenario IDs\r",
              "let scenarioIds = response.resources.map(r => r.id);\r",
              "\r",
              "// store as array\r",
              "pm.environment.set(\"scenarioIds\", JSON.stringify(scenarioIds));\r",
              "\r",
              "console.log(scenarioIds)\r",
              "// initialize index\r",
              "pm.environment.set(\"index\", 0);\r",
              "\r",
              "// initialize result array\r",
              "pm.environment.set(\"allExecutables\", JSON.stringify([]));"
