    {
      "name": "Get pipelines (executables) of all scenarios",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "console.log(pm.environment.get(\"scenarioIds\"))\r",
              "let scenarioIds = JSON.parse(pm.environment.get(\"scenarioIds\"));\r",
              "let index = pm.environment.get(\"index\");\r",
              "\r",
              "pm.environment.set(\"currentScenario\", scenarioIds[index]);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "let response = pm.response.json();\r",
              "let allExecutables = JSON.parse(pm.environment.get(\"allExecutables\"));\r",
              "\r",
              "// append current result\r",
              "allExecutables.push({\r",
              "    scenario: pm.environment.get(\"currentScenario\"),\r",
              "    executables: response.resources\r",
              "});\r",
              "\r",
              "// save back\r",
              "pm.environment.set(\"allExecutables\", JSON.stringify(allExecutables));\r",
              "\r",
              "// move to next index\r",
              "let scenarioIds = JSON.parse(pm.environment.get(\"scenarioIds\"));\r",
              "let index = parseInt(pm.environment.get(\"index\"));\r",
              "\r",
              "index++;\r",
              "pm.environment.set(\"index\", index);\r",
              "\r",
              "// loop control\r",
              "if (index < scenarioIds.length) {\r",
              "    postman.setNextRequest(\"Get Executables\"); // EXACT request name\r",
              "} else {\r",
              "    postman.setNextRequest(null);\r",
              "\r",
              "    console.log(\"FINAL RESULT:\");\r",
              "    console.log(allExecutables);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
